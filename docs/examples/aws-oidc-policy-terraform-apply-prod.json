{
  "Version": "2012-10-17",
  "Statement": [
    {
      "Sid": "ListTerraformStateBucket",
      "Effect": "Allow",
      "Action": [
        "s3:GetBucketLocation",
        "s3:ListBucket"
      ],
      "Resource": "arn:aws:s3:::formoseaniap-platform-tfstate-760259504838-ap-northeast-1-an",
      "Condition": {
        "StringLike": {
          "s3:prefix": [
            "infra/prod/*"
          ]
        }
      }
    },
    {
      "Sid": "ManageTerraformState",
      "Effect": "Allow",
      "Action": [
        "s3:DeleteObject",
        "s3:GetObject",
        "s3:PutObject"
      ],
      "Resource": [
        "arn:aws:s3:::formoseaniap-platform-tfstate-760259504838-ap-northeast-1-an/infra/prod/terraform.tfstate",
        "arn:aws:s3:::formoseaniap-platform-tfstate-760259504838-ap-northeast-1-an/infra/prod/terraform.tfstate.tflock"
      ]
    },
    {
      "Sid": "ManageSiteBuckets",
      "Effect": "Allow",
      "Action": [
        "s3:CreateBucket",
        "s3:DeleteBucket",
        "s3:GetBucketLocation",
        "s3:ListAllMyBuckets"
      ],
      "Resource": "*"
    },
    {
      "Sid": "ManageSiteBucketConfiguration",
      "Effect": "Allow",
      "Action": "s3:*",
      "Resource": [
        "arn:aws:s3:::formoseaniap-platform-prod-site-760259504838-ap-northeast-1",
        "arn:aws:s3:::formoseaniap-platform-prod-site-760259504838-ap-northeast-1/*"
      ]
    },
    {
      "Sid": "ManageCloudFront",
      "Effect": "Allow",
      "Action": "cloudfront:*",
      "Resource": "*"
    },
    {
      "Sid": "ReadCallerIdentity",
      "Effect": "Allow",
      "Action": "sts:GetCallerIdentity",
      "Resource": "*"
    }
  ]
}
