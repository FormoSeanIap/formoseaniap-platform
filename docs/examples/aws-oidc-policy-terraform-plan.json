{
  "Version": "2012-10-17",
  "Statement": [
    {
      "Sid": "ListTerraformStateBucket",
      "Effect": "Allow",
      "Action": [
        "s3:GetBucketLocation",
        "s3:ListBucket"
      ],
      "Resource": "arn:aws:s3:::formoseaniap-platform-tfstate-760259504838-ap-northeast-1-an",
      "Condition": {
        "StringLike": {
          "s3:prefix": [
            "infra/prod/*"
          ]
        }
      }
    },
    {
      "Sid": "ReadTerraformState",
      "Effect": "Allow",
      "Action": [
        "s3:GetObject"
      ],
      "Resource": [
        "arn:aws:s3:::formoseaniap-platform-tfstate-760259504838-ap-northeast-1-an/infra/prod/terraform.tfstate",
        "arn:aws:s3:::formoseaniap-platform-tfstate-760259504838-ap-northeast-1-an/infra/prod/terraform.tfstate.tflock"
      ]
    },
    {
      "Sid": "WriteTerraformPlanLock",
      "Effect": "Allow",
      "Action": [
        "s3:DeleteObject",
        "s3:PutObject"
      ],
      "Resource": "arn:aws:s3:::formoseaniap-platform-tfstate-760259504838-ap-northeast-1-an/infra/prod/terraform.tfstate.tflock"
    },
    {
      "Sid": "ReadTerraformManagedResources",
      "Effect": "Allow",
      "Action": [
        "acm:DescribeCertificate",
        "acm:ListCertificates",
        "acm:ListTagsForCertificate",
        "apigateway:GET",
        "cloudwatch:Describe*",
        "cloudwatch:GetDashboard",
        "cloudwatch:List*",
        "cloudwatch:ListTagsForResource",
        "cloudfront:Describe*",
        "cloudfront:Get*",
        "cloudfront:List*",
        "cognito-idp:Describe*",
        "cognito-idp:Get*",
        "cognito-idp:List*",
        "dynamodb:Describe*",
        "dynamodb:List*",
        "iam:GetPolicy",
        "iam:GetPolicyVersion",
        "iam:GetRole",
        "iam:GetRolePolicy",
        "iam:ListAttachedRolePolicies",
        "iam:ListRolePolicies",
        "lambda:GetFunction",
        "lambda:GetFunctionCodeSigningConfig",
        "lambda:GetPolicy",
        "lambda:ListVersionsByFunction",
        "route53:GetChange",
        "route53:GetHostedZone",
        "route53:ListHostedZones",
        "route53:ListHostedZonesByName",
        "route53:ListResourceRecordSets",
        "route53:ListTagsForResource",
        "s3:Get*",
        "s3:List*",
        "sns:Get*",
        "sns:List*",
        "sts:GetCallerIdentity"
      ],
      "Resource": "*"
    }
  ]
}
