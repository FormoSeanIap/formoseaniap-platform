{
  "Version": "2012-10-17",
  "Statement": [
    {
      "Sid": "ListTerraformStateBucket",
      "Effect": "Allow",
      "Action": [
        "s3:GetBucketLocation",
        "s3:ListBucket"
      ],
      "Resource": "arn:aws:s3:::formoseaniap-platform-tfstate-760259504838-ap-northeast-1-an",
      "Condition": {
        "StringLike": {
          "s3:prefix": [
            "infra/prod/*"
          ]
        }
      }
    },
    {
      "Sid": "ReadTerraformState",
      "Effect": "Allow",
      "Action": [
        "s3:GetObject"
      ],
      "Resource": [
        "arn:aws:s3:::formoseaniap-platform-tfstate-760259504838-ap-northeast-1-an/infra/prod/terraform.tfstate",
        "arn:aws:s3:::formoseaniap-platform-tfstate-760259504838-ap-northeast-1-an/infra/prod/terraform.tfstate.tflock"
      ]
    },
    {
      "Sid": "WriteTerraformPlanLock",
      "Effect": "Allow",
      "Action": [
        "s3:DeleteObject",
        "s3:PutObject"
      ],
      "Resource": "arn:aws:s3:::formoseaniap-platform-tfstate-760259504838-ap-northeast-1-an/infra/prod/terraform.tfstate.tflock"
    },
    {
      "Sid": "ReadTerraformManagedResources",
      "Effect": "Allow",
      "Action": [
        "cloudfront:Get*",
        "cloudfront:List*",
        "s3:Get*",
        "s3:List*",
        "sts:GetCallerIdentity"
      ],
      "Resource": "*"
    }
  ]
}
