{
  "Version": "2012-10-17",
  "Statement": [
    {
      "Sid": "AllowPullRequestTerraformPlan",
      "Effect": "Allow",
      "Principal": {
        "Federated": "arn:aws:iam::760259504838:oidc-provider/token.actions.githubusercontent.com"
      },
      "Action": "sts:AssumeRoleWithWebIdentity",
      "Condition": {
        "StringEquals": {
          "token.actions.githubusercontent.com:aud": "sts.amazonaws.com",
          "token.actions.githubusercontent.com:sub": "repo:FormoSeanIap/formoseaniap-platform:pull_request"
        }
      }
    },
    {
      "Sid": "AllowMainBranchTerraformOutput",
      "Effect": "Allow",
      "Principal": {
        "Federated": "arn:aws:iam::760259504838:oidc-provider/token.actions.githubusercontent.com"
      },
      "Action": "sts:AssumeRoleWithWebIdentity",
      "Condition": {
        "StringEquals": {
          "token.actions.githubusercontent.com:aud": "sts.amazonaws.com",
          "token.actions.githubusercontent.com:sub": "repo:FormoSeanIap/formoseaniap-platform:ref:refs/heads/main"
        }
      }
    }
  ]
}
