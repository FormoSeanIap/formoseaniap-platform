# Dependencies
node_modules/

# Build output
dist/
.cache/
site/data/
!site/data/
site/data/articles/
site/data/articles.index.json
site/data/articles.search.json
!site/data/projects.json
site/rss.xml
site/zh/rss.xml
site/sitemap.xml
site/assets/articles/

# Fingerprinted asset copies and manifest — regenerated by
# scripts/fingerprint_assets.py at build time and uploaded to S3 with a
# year-long immutable cache header. The non-fingerprinted originals stay
# committed as the canonical source.
site/assets/asset-manifest.json
site/assets/css/*.[0-9a-f][0-9a-f][0-9a-f][0-9a-f][0-9a-f][0-9a-f][0-9a-f][0-9a-f][0-9a-f][0-9a-f].css
site/assets/js/*.[0-9a-f][0-9a-f][0-9a-f][0-9a-f][0-9a-f][0-9a-f][0-9a-f][0-9a-f][0-9a-f][0-9a-f].js

# Engineering site generated outputs
site-eng/data/articles/
site-eng/data/articles.index.json
site-eng/data/articles.search.json
site-eng/rss.xml
site-eng/sitemap.xml
site-eng/assets/articles/
site-eng/assets/asset-manifest.json
site-eng/assets/css/*.[0-9a-f][0-9a-f][0-9a-f][0-9a-f][0-9a-f][0-9a-f][0-9a-f][0-9a-f][0-9a-f][0-9a-f].css
site-eng/assets/js/*.[0-9a-f][0-9a-f][0-9a-f][0-9a-f][0-9a-f][0-9a-f][0-9a-f][0-9a-f][0-9a-f][0-9a-f].js

# Shared assets synced from site/ by scripts/sync_shared_assets.py.
# site/ is the canonical source; site-eng/ mirrors these at build time.
site-eng/assets/css/admin.css
site-eng/assets/css/base.css
site-eng/assets/css/components.css
site-eng/assets/css/layout.css
site-eng/assets/css/variables.css
site-eng/assets/js/admin-analytics.js
site-eng/assets/js/articles.js
site-eng/assets/js/main.js
site-eng/assets/js/progressive-list.js
site-eng/assets/js/projects.js

# Generated at deploy time from Terraform outputs; never committed.
site/data/analytics.config.json
site-eng/data/analytics.config.json

# Logs
*.log
npm-debug.log*
yarn-debug.log*
pnpm-debug.log*

